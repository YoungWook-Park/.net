<Window x:Class="Refact.PLC.DAQ.Wpf.TestDriver.TestDriverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DAQ Test Driver - Backup_Start DB" Height="520" Width="720">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="OP100 Backup_Start DB Test" 
                   FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
        <TextBlock Grid.Row="1" Text="[Button: Fake PLC, Backup_Start=1, HandleOp100Async, Model Upsert, Empg Insert" 
                   Foreground="#555" Margin="0,0,0,12"/>

        <Button Grid.Row="2" Content="OP100 Backup_Start"
                Command="{Binding RunCommand}" Height="36" Width="180"
                VerticalAlignment="Top" HorizontalAlignment="Left" Margin="0,0,0,12"/>

        <Border Grid.Row="3" BorderBrush="#ccc" BorderThickness="1" Padding="8" 
                Background="#f9f9f9" Margin="0,12,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="220"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="DB Log" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Lines}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12" 
                                           Margin="0,2" TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
